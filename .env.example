# Database (Neon serverless Postgres — https://neon.tech)
DATABASE_URL="postgresql://<user>:<password>@<host>/neondb?sslmode=require&channel_binding=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# Admin credentials (single-user login)
ADMIN_EMAIL="admin@224tech.com"
ADMIN_PASSWORD="replace-with-strong-password"

# Anthropic (optional — required for CLOUD mode)
ANTHROPIC_API_KEY=""

# Anthropic API timeout in milliseconds (default: 30000 = 30 seconds)
ANTHROPIC_API_TIMEOUT_MS="30000"

# MCP Bridge (optional — defaults shown)
MCP_BRIDGE_PORT="3001"
MCP_BRIDGE_TIMEOUT_MS="2000"

# Cost Tracking & Alerts (optional — defaults shown)
# Spend alert threshold per agent per month in USD (default: 10)
SPEND_ALERT_THRESHOLD_USD="10"
